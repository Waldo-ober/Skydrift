# ---------------------------------------------------------------
# Copy this file to .env.local and fill in real values before deploying.
# While these are unset, the app runs in MOCK MODE — DocuSign calls
# are simulated locally so you can test the full flow with no real
# account or cost.
# ---------------------------------------------------------------

# --- Supabase (free tier: https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- DocuSign (from Kim's account: Admin > Apps and Keys) ---
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_TEMPLATE_ID=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_WEBHOOK_SECRET=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Mock mode toggle ---
# Set to "true" explicitly to force mock mode even with real keys present
# (useful for demoing without touching the real DocuSign account).
MOCK_MODE=true
